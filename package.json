{
  "name": "credvaultix",
  "version": "1.0.2",
  "description": "A sleek Windows desktop CredVaultix account, 2FA, and service information vault with Material Design 3",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite --host 127.0.0.1",
    "electron:build": "vite build && electron-builder --win",
    "postinstall": "electron-rebuild",
    "rebuild": "electron-rebuild",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "zzf-857",
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^5.16.0",
    "@mui/material": "^5.16.0",
    "@types/papaparse": "^5.5.2",
    "better-sqlite3": "^11.3.0",
    "electron-updater": "^6.8.9",
    "otpauth": "^9.5.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.3.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.personal.credvaultix",
    "productName": "CredVaultix",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "win": {
      "icon": "assets/app.ico",
      "artifactName": "CredVaultix-${version}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "artifactName": "CredVaultix-Setup-${version}.${ext}",
      "installerIcon": "assets/app.ico",
      "uninstallerIcon": "assets/app.ico",
      "installerHeaderIcon": "assets/app.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "CredVaultix"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "zzf-857",
        "repo": "CredVaultix"
      }
    ]
  }
}
