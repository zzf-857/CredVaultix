{
  "name": "credvaultix",
  "version": "1.1.0",
  "description": "A sleek Windows desktop CredVaultix account, 2FA, and service information vault with Material Design 3",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build": "npm run electron:build",
    "preview": "vite preview",
    "electron:dev": "vite --host 127.0.0.1",
    "electron:build": "npm run build:renderer && electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-builder install-app-deps",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm test && npm run typecheck && npm run build:renderer",
    "release:check": "node scripts/release-check.mjs",
    "release:assets": "node scripts/verify-release-assets.mjs",
    "release:notes": "node scripts/extract-release-notes.mjs"
  },
  "author": "zzf-857",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^5.16.0",
    "@mui/material": "^5.16.0",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9",
    "otpauth": "^9.5.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.1.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "js-yaml": "4.3.0",
    "cosmiconfig": {
      "yaml": "1.10.3"
    }
  },
  "build": {
    "appId": "com.personal.credvaultix",
    "productName": "CredVaultix",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "win": {
      "icon": "assets/app.ico",
      "artifactName": "CredVaultix-${version}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "artifactName": "CredVaultix-Setup-${version}.${ext}",
      "installerIcon": "assets/app.ico",
      "uninstallerIcon": "assets/app.ico",
      "installerHeaderIcon": "assets/app.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "CredVaultix"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "zzf-857",
        "repo": "CredVaultix"
      }
    ]
  }
}
